# ── Render.com Environment Variables ──
# Copy these to your Render service → Environment tab

NODE_ENV=production
PORT=10000

# PostgreSQL (Render Managed DB — copy from Render dashboard)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis (Render Redis — copy from Render dashboard, or use free tier like Upstash)
REDIS_URL=redis://default:password@host:6379

# JWT Secrets (generate with: openssl rand -hex 64)
JWT_ACCESS_SECRET=your-access-secret-min-64-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-64-chars

# App URL (your Render service URL)
APP_URL=https://your-app.onrender.com

# Email (use Gmail, Resend, or SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@your-domain.com

# Optional: Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional: OpenAI (for vector search)
OPENAI_API_KEY=
